<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PlasticButtonBaseStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="#52FFFFFF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">

                        <Border x:Name="ShadowLayer"
                                Margin="0,3,0,0"
                                CornerRadius="16"
                                Background="#1E07111F" />

                        <Border x:Name="OuterShell"
                                CornerRadius="16"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#C6FFFFFF" Offset="0" />
                                    <GradientStop Color="{Binding Background.(SolidColorBrush.Color), RelativeSource={RelativeSource TemplatedParent}}" Offset="0.18" />
                                    <GradientStop Color="{Binding Background.(SolidColorBrush.Color), RelativeSource={RelativeSource TemplatedParent}}" Offset="0.72" />
                                    <GradientStop Color="#72040B16" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Border x:Name="InnerFace"
                                        Margin="1"
                                        CornerRadius="15">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#1EFFFFFF" Offset="0" />
                                            <GradientStop Color="#05FFFFFF" Offset="0.35" />
                                            <GradientStop Color="#09030A12" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <Border x:Name="EdgeRim"
                                        Margin="1"
                                        CornerRadius="15"
                                        BorderBrush="#16FFFFFF"
                                        BorderThickness="1"
                                        Opacity="0.7" />

                                <Border x:Name="GlossLayer"
                                        Margin="2,2,2,18"
                                        CornerRadius="14"
                                        IsHitTestVisible="False">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#40FFFFFF" Offset="0" />
                                            <GradientStop Color="#10FFFFFF" Offset="0.52" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ShadowLayer" Property="Background" Value="#2607111F" />
                            <Setter TargetName="OuterShell" Property="BorderBrush" Value="#7EE7F3FF" />
                            <Setter TargetName="EdgeRim" Property="Opacity" Value="0.95" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ShadowLayer" Property="Margin" Value="0,1,0,0" />
                            <Setter TargetName="OuterShell" Property="Margin" Value="0,1,0,0" />
                            <Setter TargetName="GlossLayer" Property="Opacity" Value="0.45" />
                            <Setter TargetName="EdgeRim" Property="Opacity" Value="0.45" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="OuterShell" Property="Opacity" Value="0.55" />
                            <Setter TargetName="ShadowLayer" Property="Opacity" Value="0.2" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PlasticButtonBaseStyle}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="#315A86" />
        <Setter Property="Foreground" Value="#F8FBFF" />
        <Setter Property="BorderBrush" Value="#7FB7E7" />
    </Style>

    <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="#A65C12" />
        <Setter Property="Foreground" Value="#FEF3C7" />
        <Setter Property="BorderBrush" Value="#FFD27A" />
    </Style>

    <Style x:Key="ListActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Width" Value="120" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,8" />
    </Style>
</ResourceDictionary>
