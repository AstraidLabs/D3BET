<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <LinearGradientBrush x:Key="WindowBackgroundBrush" EndPoint="1,1" StartPoint="0,0">
        <GradientStop Color="#08111F" Offset="0" />
        <GradientStop Color="#0D1B31" Offset="0.5" />
        <GradientStop Color="#132847" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="PanelBrush" Color="#AA0E1726" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#33E2E8F0" />
    <SolidColorBrush x:Key="InputBrush" Color="#C40C1626" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#3AF8FAFC" />
    <SolidColorBrush x:Key="AccentBrush" Color="#F97316" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A7B6CA" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />
    <SolidColorBrush x:Key="MutedBadgeBrush" Color="#334155" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
</ResourceDictionary>
