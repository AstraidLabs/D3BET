<Window x:Class="BettingApp.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Přihlášení D3Bet"
        Width="480"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Opacity="0"
        FontFamily="{StaticResource AppFontFamily}">
    <Window.Resources>
        <Storyboard x:Key="WindowIntroStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowIntroStoryboard}" />
        </EventTrigger>
    </Window.Triggers>
    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Border Margin="24"
                Padding="28"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="34">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" Opacity="0.18" ShadowDepth="0" Color="#FF020617" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="{StaticResource FontSizeMeta}"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           Text="D3BET" />

                <TextBlock Grid.Row="1"
                           Margin="0,6,0,0"
                           FontSize="{StaticResource FontSizePanelTitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           Text="Přihlášení provozovatele" />

                <TextBlock Grid.Row="2"
                           Margin="0,6,0,22"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           Text="Přihlaste se svým provozním účtem a bezpečně otevřete interní správu kurzů, tiketů a vyhodnocení." />

                <Border Grid.Row="3"
                        Margin="0,0,0,6"
                        Padding="12,10"
                        Background="#3F7F1D1D"
                        BorderBrush="#7F1D1D"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Foreground="#FECACA"
                               TextWrapping="Wrap"
                               Text="{Binding ErrorMessage}" />
                </Border>

                <StackPanel Grid.Row="4" Margin="0,0,0,16">
                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="Uživatelské jméno" />
                    <TextBox x:Name="UserNameTextBox"
                             Style="{StaticResource FluentTextBoxStyle}"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="5" Margin="0,0,0,22">
                    <TextBlock Style="{StaticResource LabelTextStyle}" Text="Heslo" />
                    <PasswordBox x:Name="PasswordBox"
                                 Background="{StaticResource InputBrush}"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 BorderBrush="{StaticResource InputBorderBrush}"
                                 BorderThickness="1"
                                 Height="52"
                                 MinHeight="52"
                                 Padding="14,12"
                                 FontSize="14"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 SelectionBrush="#99F97316"
                                 VerticalContentAlignment="Center" />
                </StackPanel>

                <Button Grid.Row="6"
                        x:Name="LoginButton"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="48"
                        Content="Přihlásit a pokračovat"
                        Click="OnLoginButtonClick" />

                <TextBlock Grid.Row="7"
                           Margin="0,14,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Visibility="{Binding IsLoggingIn, Converter={StaticResource BoolToVisibility}}"
                           Text="Ověřujeme přihlašovací údaje..." />
            </Grid>
        </Border>
    </Grid>
</Window>
