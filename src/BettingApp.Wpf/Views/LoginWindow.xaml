<Window x:Class="BettingApp.Wpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Přihlášení D3Bet"
        Width="1180"
        Height="760"
        MinWidth="1040"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#08111F"
        FontFamily="{StaticResource AppFontFamily}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <LinearGradientBrush x:Key="WindowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#08111F" Offset="0" />
            <GradientStop Color="#0D1B31" Offset="0.55" />
            <GradientStop Color="#132847" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PanelBrush" Color="#F10F172A" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#33E2E8F0" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F97316" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A7B6CA" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="TextBoxStyleLocal" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#C40C1626" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#3AF8FAFC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PasswordBoxStyleLocal" TargetType="PasswordBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#C40C1626" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#3AF8FAFC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PrimaryButtonStyleLocal" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="SecondaryButtonStyleLocal" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyleLocal}">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#334155" />
        </Style>

        <Style x:Key="TabControlStyleLocal" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="TabItemStyleLocal" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Background" Value="#80111C2E" />
            <Setter Property="BorderBrush" Value="#33E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="340" Height="340" Canvas.Left="-90" Canvas.Top="-120" Fill="#22F97316" />
            <Ellipse Width="240" Height="240" Canvas.Right="30" Canvas.Top="40" Fill="#1F38BDF8" />
            <Ellipse Width="300" Height="300" Canvas.Left="860" Canvas.Top="520" Fill="#1822C55E" />
        </Canvas>

        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.65*" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,18,0"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock FontSize="15" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="D3BET" />
                        <TextBlock Margin="0,8,0,0" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="Desktop self-service bez webového prohlížeče" TextWrapping="Wrap" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Text="Registrace, aktivace, obnova hesla i samotné přihlášení probíhají přímo v klientovi a používají stejný design jako zbytek D3Bet."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TabControl Grid.Row="1"
                                Style="{StaticResource TabControlStyleLocal}"
                                SelectedIndex="{Binding SelectedTabIndex}">
                        <TabItem Header="Přihlášení" Style="{StaticResource TabItemStyleLocal}">
                            <StackPanel Margin="16">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Uživatelské jméno nebo e-mail" />
                                <TextBox Margin="0,0,0,14" Style="{StaticResource TextBoxStyleLocal}" Text="{Binding LoginUserName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Heslo" />
                                <PasswordBox x:Name="LoginPasswordBox" Margin="0,0,0,18" Style="{StaticResource PasswordBoxStyleLocal}" />
                                <Button Style="{StaticResource PrimaryButtonStyleLocal}" Click="LoginButton_Click" Content="Přihlásit do D3Bet" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Registrace" Style="{StaticResource TabItemStyleLocal}">
                            <StackPanel Margin="16">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Uživatelské jméno" />
                                <TextBox Margin="0,0,0,12" Style="{StaticResource TextBoxStyleLocal}" Text="{Binding RegisterUserName, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="E-mail" />
                                <TextBox Margin="0,0,0,12" Style="{StaticResource TextBoxStyleLocal}" Text="{Binding RegisterEmail, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Heslo" />
                                <PasswordBox x:Name="RegisterPasswordBox" Margin="0,0,0,12" Style="{StaticResource PasswordBoxStyleLocal}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Potvrzení hesla" />
                                <PasswordBox x:Name="RegisterConfirmPasswordBox" Margin="0,0,0,18" Style="{StaticResource PasswordBoxStyleLocal}" />
                                <Button Style="{StaticResource PrimaryButtonStyleLocal}" Click="RegisterButton_Click" Content="Vytvořit účet" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Aktivace" Style="{StaticResource TabItemStyleLocal}">
                            <StackPanel Margin="16">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Uživatelské jméno nebo e-mail" />
                                <TextBox Margin="0,0,0,12" Style="{StaticResource TextBoxStyleLocal}" Text="{Binding ActivationUserNameOrEmail, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Aktivační token" />
                                <TextBox Margin="0,0,0,18"
                                         MinHeight="108"
                                         Padding="12,10"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         Background="#C40C1626"
                                         Foreground="{StaticResource PrimaryTextBrush}"
                                         BorderBrush="#3AF8FAFC"
                                         BorderThickness="1"
                                         Text="{Binding ActivationToken, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Style="{StaticResource PrimaryButtonStyleLocal}" Click="ActivateButton_Click" Content="Aktivovat účet" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Reaktivace" Style="{StaticResource TabItemStyleLocal}">
                            <StackPanel Margin="16">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Uživatelské jméno nebo e-mail" />
                                <TextBox Margin="0,0,0,18" Style="{StaticResource TextBoxStyleLocal}" Text="{Binding ReactivationUserNameOrEmail, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Style="{StaticResource PrimaryButtonStyleLocal}" Click="ReactivateButton_Click" Content="Poslat nový aktivační krok" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Obnova hesla" Style="{StaticResource TabItemStyleLocal}">
                            <StackPanel Margin="16">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Uživatelské jméno nebo e-mail" />
                                <TextBox Margin="0,0,0,18" Style="{StaticResource TextBoxStyleLocal}" Text="{Binding ForgotUserNameOrEmail, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Style="{StaticResource PrimaryButtonStyleLocal}" Click="ForgotPasswordButton_Click" Content="Připravit obnovu hesla" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Reset hesla" Style="{StaticResource TabItemStyleLocal}">
                            <StackPanel Margin="16">
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Uživatelské jméno nebo e-mail" />
                                <TextBox Margin="0,0,0,12" Style="{StaticResource TextBoxStyleLocal}" Text="{Binding ResetUserNameOrEmail, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Reset token" />
                                <TextBox Margin="0,0,0,12"
                                         MinHeight="96"
                                         Padding="12,10"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         Background="#C40C1626"
                                         Foreground="{StaticResource PrimaryTextBrush}"
                                         BorderBrush="#3AF8FAFC"
                                         BorderThickness="1"
                                         Text="{Binding ResetToken, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Nové heslo" />
                                <PasswordBox x:Name="ResetPasswordBox" Margin="0,0,0,12" Style="{StaticResource PasswordBoxStyleLocal}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Potvrzení nového hesla" />
                                <PasswordBox x:Name="ResetConfirmPasswordBox" Margin="0,0,0,18" Style="{StaticResource PasswordBoxStyleLocal}" />
                                <Button Style="{StaticResource PrimaryButtonStyleLocal}" Click="ResetPasswordButton_Click" Content="Změnit heslo" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding StatusTitle}" />
                        <TextBlock Margin="0,10,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            Padding="16"
                            Background="#80111C2E"
                            BorderBrush="#1FF8FAFC"
                            BorderThickness="1"
                            CornerRadius="20">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="Poznámka k e-mailům" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="Dokud nebude nasazený produkční OAuth2 EmailSender, server vrací aktivační a reset token jako preview přímo do klienta."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="16"
                            Background="#A30F172A"
                            BorderBrush="#22F8FAFC"
                            BorderThickness="1"
                            CornerRadius="20"
                            Visibility="{Binding HasPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Foreground="{StaticResource PrimaryTextBrush}" FontFamily="Consolas" Text="{Binding PreviewText}" TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Width="140"
                                Style="{StaticResource SecondaryButtonStyleLocal}"
                                Click="CancelButton_Click"
                                Content="Zavřít" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
