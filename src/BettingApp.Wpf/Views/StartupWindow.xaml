<Window x:Class="BettingApp.Wpf.Views.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spouštění D3Bet"
        Width="560"
        Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Opacity="0"
        FontFamily="{StaticResource AppFontFamily}">
    <Window.Resources>
        <Storyboard x:Key="WindowIntroStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="PanelIntroStoryboard">
            <DoubleAnimation Storyboard.TargetName="StartupPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="StartupPanelTranslate"
                             Storyboard.TargetProperty="Y"
                             From="22"
                             To="0"
                             Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="AccentPulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="AccentOrb"
                             Storyboard.TargetProperty="Opacity"
                             From="0.35"
                             To="0.75"
                             Duration="0:0:1.6">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AccentOrbScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="1.08"
                             Duration="0:0:1.6">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="AccentOrbScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="1.08"
                             Duration="0:0:1.6">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="BlueOrbFloatStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BlueOrbTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0"
                             To="-14"
                             Duration="0:0:2.2">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BlueOrb"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4"
                             To="0.7"
                             Duration="0:0:2.2">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ProgressGlowStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation Storyboard.TargetName="ProgressGlowStop"
                            Storyboard.TargetProperty="Color"
                            From="#FFF97316"
                            To="#FFFFB26B"
                            Duration="0:0:1.1">
                <ColorAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </ColorAnimation.EasingFunction>
            </ColorAnimation>
        </Storyboard>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowIntroStoryboard}" />
            <BeginStoryboard Storyboard="{StaticResource PanelIntroStoryboard}" />
            <BeginStoryboard Storyboard="{StaticResource AccentPulseStoryboard}" />
            <BeginStoryboard Storyboard="{StaticResource BlueOrbFloatStoryboard}" />
            <BeginStoryboard Storyboard="{StaticResource ProgressGlowStoryboard}" />
        </EventTrigger>
    </Window.Triggers>
    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Canvas IsHitTestVisible="False">
            <Ellipse x:Name="AccentOrb" Width="260" Height="260" Canvas.Left="-60" Canvas.Top="-90" Fill="#20F97316" Opacity="0.45">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="AccentOrbScale" CenterX="130" CenterY="130" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse x:Name="BlueOrb" Width="220" Height="220" Canvas.Right="-40" Canvas.Top="20" Fill="#1838BDF8" Opacity="0.5">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="BlueOrbTranslate" />
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <Border x:Name="StartupPanel"
                Margin="24"
                Padding="28"
                Opacity="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="34">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" Opacity="0.18" ShadowDepth="0" Color="#FF020617" />
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform x:Name="StartupPanelTranslate" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="{StaticResource FontSizeMeta}" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="D3BET" />
                    <TextBlock Margin="{StaticResource LabelMargin}" FontSize="{StaticResource FontSizePanelTitle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding Title}" />
                    <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding Detail}" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,22,0,0"
                        Padding="14,10"
                        Background="#A30F172A"
                        BorderBrush="#22F8FAFC"
                        BorderThickness="1"
                        CornerRadius="22">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" Opacity="0.12" ShadowDepth="0" Color="#FF020617" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource SecondaryTextBrush}" Text="Průběh spuštění" />
                        <TextBlock Margin="0,6,0,0" FontSize="{StaticResource FontSizeSectionTitle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding ProgressLabel}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        Padding="14,10"
                        Background="#80111C2E"
                        BorderBrush="#1FF8FAFC"
                        BorderThickness="1"
                        CornerRadius="20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="{StaticResource AccentBrush}" FontWeight="Bold" Text="LIVE" />
                        <TextBlock Margin="10,0,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="Bezpečný start systému, synchronizace dat a připravený provoz v jednom kroku." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ProgressBar Grid.Row="3"
                             Height="14"
                             Margin="0,20,0,0"
                             Maximum="100"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             Background="#1E293B">
                    <ProgressBar.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFF97316" Offset="0" />
                            <GradientStop x:Name="ProgressGlowStop" Color="#FFFFB26B" Offset="1" />
                        </LinearGradientBrush>
                    </ProgressBar.Foreground>
                </ProgressBar>

                <TextBlock Grid.Row="4"
                           Margin="0,20,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="D3Bet se otevře automaticky, jakmile bude vše připravené pro plynulý provoz." />
            </Grid>
        </Border>
    </Grid>
</Window>
