<Window x:Class="BettingApp.Wpf.Views.MarketEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="D3Bet | Editor události"
        Height="420"
        Width="620"
        WindowStartupLocation="CenterOwner"
        Background="#08111F">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#F10F172A" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#33E2E8F0" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F97316" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A7B6CA" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="TextBoxStyleLocal" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#C40C1626" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#3AF8FAFC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PrimaryButtonStyleLocal" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SecondaryButtonStyleLocal" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyleLocal}">
            <Setter Property="Background" Value="#315A86" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#7FB7E7" />
        </Style>

        <Style x:Key="CheckBoxStyleLocal" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="#08111F">
        <Grid Margin="24">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Text="{Binding TitleText}" />
                    <TextBlock Margin="0,8,0,18"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="Provozovatel zde vypisuje událost a výchozí kurz. Další pohyb kurzu už řídí systém automaticky." />

                    <TextBlock Style="{StaticResource LabelStyle}" Text="Název události" />
                    <TextBox Style="{StaticResource TextBoxStyleLocal}"
                             Text="{Binding EventName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,14,0,6" Style="{StaticResource LabelStyle}" Text="Výchozí kurz" />
                    <TextBox Width="180"
                             Style="{StaticResource TextBoxStyleLocal}"
                             Text="{Binding OpeningOdds, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Margin="0,18,0,0"
                              Style="{StaticResource CheckBoxStyleLocal}"
                              IsChecked="{Binding IsActive}"
                              Content="Událost je aktivní pro příjem sázek" />

                    <StackPanel Margin="0,22,0,0" Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButtonStyleLocal}"
                                Command="{Binding SaveCommand}"
                                Content="{Binding SaveButtonText}" />
                        <Button Style="{StaticResource SecondaryButtonStyleLocal}"
                                Content="Zavřít"
                                Command="{Binding CancelCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
