<Window x:Class="BettingApp.Wpf.Views.UserAdministrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="D3Bet | Detail uživatele"
        Height="820"
        Width="1180"
        MinHeight="720"
        MinWidth="1000"
        WindowStartupLocation="CenterOwner"
        Background="#08111F">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#F10F172A" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#33E2E8F0" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F97316" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A7B6CA" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#34D399" />

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="TextBoxStyleLocal" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#C40C1626" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#3AF8FAFC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PrimaryButtonStyleLocal" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SecondaryButtonStyleLocal" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyleLocal}">
            <Setter Property="Background" Value="#315A86" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#7FB7E7" />
        </Style>

        <Style x:Key="TicketActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="#315A86" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#7FB7E7" />
        </Style>

        <Style x:Key="CheckBoxStyleLocal" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SubTabControlStyleLocal" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="SubTabItemStyleLocal" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Background" Value="#223754" />
            <Setter Property="BorderBrush" Value="#4D7FB7E7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16,16,8,8"
                                Margin="{TemplateBinding Margin}">
                            <Grid>
                                <Border Margin="1"
                                        CornerRadius="15,15,7,7"
                                        BorderBrush="#18FFFFFF"
                                        BorderThickness="1"
                                        IsHitTestVisible="False" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#88BFE6FF" />
                                <Setter TargetName="TabBorder" Property="Background" Value="#294B71" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#3A628D" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#D6F97316" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TabBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridHeaderStyleLocal" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#122033" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#2234475E" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="GridListViewItemStyleLocal" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="BorderBrush" Value="#18283B52" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1622354A" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#22314A67" />
                    <Setter Property="BorderBrush" Value="#55F97316" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridListViewStyleLocal" TargetType="ListView">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource GridListViewItemStyleLocal}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </Window.Resources>

    <Grid Background="#08111F">
        <Grid Margin="24">
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding EditorTitle}" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="{Binding EditorSubtitle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Width="160"
                                    Style="{StaticResource PrimaryButtonStyleLocal}"
                                    Command="{Binding SaveUserCommand}"
                                    Content="Uložit změny" />
                            <Button Width="150"
                                    Style="{StaticResource SecondaryButtonStyleLocal}"
                                    Click="CloseWindow"
                                    Content="Zavřít okno" />
                        </StackPanel>
                    </DockPanel>

                    <TabControl Grid.Row="1"
                                Margin="0,24,0,0"
                                Style="{StaticResource SubTabControlStyleLocal}">
                        <TabItem Header="Účet" Style="{StaticResource SubTabItemStyleLocal}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.3*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,18,0">
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Základní údaje" />
                                        <TextBlock Margin="0,4,0,14"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Text="Upravte přihlášení, aktivaci účtu a role, které má uživatel v systému k dispozici." />

                                        <Border Padding="14"
                                                Margin="0,0,0,14"
                                                Background="#09111C2E"
                                                BorderBrush="#2234475E"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource LabelStyle}" Text="Stav účtu" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           Text="{Binding AccountStatusSummary}"
                                                           TextWrapping="Wrap" />
                                                <WrapPanel Margin="0,12,0,0">
                                                    <Button Width="130" Style="{StaticResource SecondaryButtonStyleLocal}" Command="{Binding ActivateUserCommand}" Content="Aktivovat" />
                                                    <Button Width="130" Style="{StaticResource SecondaryButtonStyleLocal}" Command="{Binding DeactivateUserCommand}" Content="Deaktivovat" />
                                                    <Button Width="130" Style="{StaticResource SecondaryButtonStyleLocal}" Command="{Binding BlockUserCommand}" Content="Blokovat" />
                                                    <Button Width="130" Style="{StaticResource SecondaryButtonStyleLocal}" Margin="0" Command="{Binding UnblockUserCommand}" Content="Odblokovat" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Uživatelské jméno" />
                                        <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,12,0,6" Style="{StaticResource LabelStyle}" Text="E-mail" />
                                        <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                                        <CheckBox Margin="0,14,0,0"
                                                  Style="{StaticResource CheckBoxStyleLocal}"
                                                  IsChecked="{Binding EmailConfirmed}"
                                                  Content="Účet je aktivní a může se přihlásit" />

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource LabelStyle}" Text="Nové heslo" />
                                        <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Text="U existujícího účtu nechte pole prázdné, pokud heslo nechcete měnit."
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Role a přístupy" />
                                        <TextBlock Margin="0,4,0,14"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Text="Zaškrtněte, do jaké části D3Bet má mít uživatel přístup." />

                                        <ItemsControl ItemsSource="{Binding AvailableRoles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Margin="0,0,0,10"
                                                              Style="{StaticResource CheckBoxStyleLocal}"
                                                              IsChecked="{Binding IsSelected}"
                                                              Content="{Binding Name}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Kredit" Style="{StaticResource SubTabItemStyleLocal}">
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <Border Margin="0,0,18,0" Padding="18" Background="#09111C2E" BorderBrush="#2234475E" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Přehled kreditu" />
                                        <TextBlock Margin="0,12,0,0" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Text="{Binding WalletSummary}" />
                                        <TextBlock Margin="0,8,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding WalletRateSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Padding="18" Background="#09111C2E" BorderBrush="#2234475E" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Ruční úprava kreditu" />
                                        <TextBlock Margin="0,4,0,14" Foreground="{StaticResource SecondaryTextBrush}" Text="Použijte pro dorovnání zůstatku, opravu dobití nebo mimořádné zásahy správce." />

                                        <WrapPanel>
                                            <StackPanel Width="160" Margin="0,0,12,12">
                                                <TextBlock Style="{StaticResource LabelStyle}" Text="Změna kreditu" />
                                                <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding CreditAdjustmentAmount, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Width="160" Margin="0,0,12,12">
                                                <TextBlock Style="{StaticResource LabelStyle}" Text="Částka v měně" />
                                                <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding CreditAdjustmentMoneyAmount, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Width="140" Margin="0,0,0,12">
                                                <TextBlock Style="{StaticResource LabelStyle}" Text="Měna" />
                                                <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding CreditAdjustmentCurrencyCode, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </WrapPanel>

                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Důvod úpravy" />
                                        <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding CreditAdjustmentReason, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Margin="0,12,0,6" Style="{StaticResource LabelStyle}" Text="Interní reference" />
                                        <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding CreditAdjustmentReference, UpdateSourceTrigger=PropertyChanged}" />

                                        <Button Width="220" Margin="0,16,0,0" Style="{StaticResource PrimaryButtonStyleLocal}" Command="{Binding ApplyCreditAdjustmentCommand}" Content="Provést úpravu kreditu" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Sázky" Style="{StaticResource SubTabItemStyleLocal}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Padding="16" Background="#09111C2E" BorderBrush="#2234475E" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Výhry a zásahy správce" />
                                        <TextBlock Margin="0,4,0,12" Foreground="{StaticResource SecondaryTextBrush}" Text="Sem napište krátké vysvětlení, které se uloží k ručnímu připsání výhry, jejímu odebrání nebo k rozhodnutí o výběru." TextWrapping="Wrap" />
                                        <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding WithdrawalDecisionReason, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>

                                <ListView Grid.Row="1" Margin="0,16,0,0" Style="{StaticResource GridListViewStyleLocal}" ItemsSource="{Binding Bets}">
                                    <ListView.View>
                                        <GridView ColumnHeaderContainerStyle="{StaticResource GridHeaderStyleLocal}">
                                            <GridViewColumn Header="Událost" Width="220" DisplayMemberBinding="{Binding EventName}" />
                                            <GridViewColumn Header="Výsledek" Width="140" DisplayMemberBinding="{Binding OutcomeDisplay}" />
                                            <GridViewColumn Header="Vklad" Width="140" DisplayMemberBinding="{Binding StakeDisplay}" />
                                            <GridViewColumn Header="Možná výhra" Width="140" DisplayMemberBinding="{Binding PotentialPayoutDisplay}" />
                                            <GridViewColumn Header="Výplata" Width="160" DisplayMemberBinding="{Binding PayoutStatusDisplay}" />
                                            <GridViewColumn Header="Vsazeno" Width="150" DisplayMemberBinding="{Binding PlacedAtDisplay}" />
                                            <GridViewColumn Header="Rychlé vyhodnocení" Width="220">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <WrapPanel>
                                                            <Button Width="68" Style="{StaticResource TicketActionButtonStyle}" Command="{Binding DataContext.MarkBetAsWonCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="Výhra" />
                                                            <Button Width="68" Style="{StaticResource TicketActionButtonStyle}" Command="{Binding DataContext.MarkBetAsLostCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="Prohra" />
                                                            <Button Width="68" Style="{StaticResource TicketActionButtonStyle}" Margin="0" Command="{Binding DataContext.ResetBetOutcomeCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="Vrátit" />
                                                        </WrapPanel>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Finance" Width="250">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <WrapPanel>
                                                            <Button Width="112" Style="{StaticResource TicketActionButtonStyle}" Command="{Binding DataContext.PayoutBetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="Připsat výhru" />
                                                            <Button Width="112" Style="{StaticResource TicketActionButtonStyle}" Command="{Binding DataContext.ReverseBetPayoutCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="Odebrat výhru" />
                                                            <Button Width="112" Style="{StaticResource TicketActionButtonStyle}" Command="{Binding DataContext.RefundBetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="Vrátit kredit" />
                                                            <Button Width="80" Style="{StaticResource TicketActionButtonStyle}" Margin="0" Command="{Binding DataContext.DeleteBetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Content="Smazat" />
                                                        </WrapPanel>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Výběry" Style="{StaticResource SubTabItemStyleLocal}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Padding="16" Background="#09111C2E" BorderBrush="#2234475E" BorderThickness="1" CornerRadius="16">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Rozhodnutí o výběru" />
                                        <TextBlock Margin="0,4,0,12" Foreground="{StaticResource SecondaryTextBrush}" Text="Tady rozhodujete, zda hráči výběr potvrdíte, nebo mu kredit vrátíte zpět do peněženky." TextWrapping="Wrap" />
                                        <TextBox Style="{StaticResource TextBoxStyleLocal}" Text="{Binding WithdrawalDecisionReason, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Border>

                                <ListView Grid.Row="1" Margin="0,16,0,0" Style="{StaticResource GridListViewStyleLocal}" ItemsSource="{Binding Withdrawals}">
                                    <ListView.View>
                                        <GridView ColumnHeaderContainerStyle="{StaticResource GridHeaderStyleLocal}">
                                            <GridViewColumn Header="Stav" Width="130" DisplayMemberBinding="{Binding StatusDisplay}" />
                                            <GridViewColumn Header="Kredit" Width="120" DisplayMemberBinding="{Binding AmountDisplay}" />
                                            <GridViewColumn Header="Měna" Width="120" DisplayMemberBinding="{Binding MoneyDisplay}" />
                                            <GridViewColumn Header="Důvod hráče" Width="240" DisplayMemberBinding="{Binding Reason}" />
                                            <GridViewColumn Header="Reference" Width="170" DisplayMemberBinding="{Binding Reference}" />
                                            <GridViewColumn Header="Požádáno" Width="150" DisplayMemberBinding="{Binding RequestedAtDisplay}" />
                                            <GridViewColumn Header="Vyřízeno" Width="150" DisplayMemberBinding="{Binding ProcessedAtDisplay}" />
                                            <GridViewColumn Header="Poznámka správce" Width="260" DisplayMemberBinding="{Binding ProcessedReason}" />
                                            <GridViewColumn Header="Akce" Width="220">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <WrapPanel>
                                                            <Button Width="100"
                                                                    Command="{Binding DataContext.ApproveWithdrawalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="Schválit">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource TicketActionButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPending}" Value="False">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Button Width="110"
                                                                    Margin="0"
                                                                    Command="{Binding DataContext.RejectWithdrawalCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="Vrátit kredit">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource TicketActionButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPending}" Value="False">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </WrapPanel>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Historie" Style="{StaticResource SubTabItemStyleLocal}">
                            <ListView Margin="0,10,0,0" Style="{StaticResource GridListViewStyleLocal}" ItemsSource="{Binding Transactions}">
                                <ListView.View>
                                    <GridView ColumnHeaderContainerStyle="{StaticResource GridHeaderStyleLocal}">
                                        <GridViewColumn Header="Typ" Width="140" DisplayMemberBinding="{Binding TypeDisplay}" />
                                        <GridViewColumn Header="Kredit" Width="140" DisplayMemberBinding="{Binding AmountDisplay}" />
                                        <GridViewColumn Header="Měna" Width="140" DisplayMemberBinding="{Binding MoneyDisplay}" />
                                        <GridViewColumn Header="Popis" Width="280" DisplayMemberBinding="{Binding Description}" />
                                        <GridViewColumn Header="Reference" Width="160" DisplayMemberBinding="{Binding Reference}" />
                                        <GridViewColumn Header="Čas" Width="160" DisplayMemberBinding="{Binding CreatedAtDisplay}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>

                        <TabItem Header="Doklady" Style="{StaticResource SubTabItemStyleLocal}">
                            <ListView Margin="0,10,0,0" Style="{StaticResource GridListViewStyleLocal}" ItemsSource="{Binding Receipts}">
                                <ListView.View>
                                    <GridView ColumnHeaderContainerStyle="{StaticResource GridHeaderStyleLocal}">
                                        <GridViewColumn Header="Číslo dokladu" Width="170" DisplayMemberBinding="{Binding DocumentNumber}" />
                                        <GridViewColumn Header="Typ dokladu" Width="230" DisplayMemberBinding="{Binding Title}" />
                                        <GridViewColumn Header="Kredit" Width="140" DisplayMemberBinding="{Binding AmountDisplay}" />
                                        <GridViewColumn Header="Měna" Width="140" DisplayMemberBinding="{Binding MoneyDisplay}" />
                                        <GridViewColumn Header="Shrnutí" Width="360" DisplayMemberBinding="{Binding Summary}" />
                                        <GridViewColumn Header="Vystaveno" Width="160" DisplayMemberBinding="{Binding IssuedAtDisplay}" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
