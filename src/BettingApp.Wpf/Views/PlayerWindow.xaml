<Window x:Class="BettingApp.Wpf.Views.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="D3Bet Hráč"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="{StaticResource AppFontFamily}">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="1.3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,16,0">
            <Border Padding="22" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="28">
                <StackPanel>
                    <TextBlock FontSize="{StaticResource FontSizeMeta}" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Text="D3BET PLAYER" />
                    <TextBlock Margin="0,8,0,0" FontSize="{StaticResource FontSizePanelTitle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding WelcomeMessage}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,18,0,0" FontSize="{StaticResource FontSizeSectionTitle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="D3Kredit peněženka" />
                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding WalletSummary}" TextWrapping="Wrap" />

                    <TextBlock Margin="0,16,0,6" Foreground="{StaticResource SecondaryTextBrush}" Text="Dobít testovací kredit" />
                    <DockPanel LastChildFill="False">
                        <TextBox Width="160" Text="{Binding TopUpAmount, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Width="160" Margin="12,0,0,0" Command="{Binding TopUpCommand}" Content="Dobít kredit" />
                    </DockPanel>

                    <StackPanel Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Width="120" Margin="0,0,12,0" Command="{Binding RefreshCommand}" Content="Obnovit" />
                        <Button Width="120" Margin="0,0,12,0" Command="{Binding OpenProfileCommand}" Content="Můj profil" />
                        <Button Width="140" Command="{Binding SwitchAccountCommand}" Content="Změnit účet" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0" Padding="22" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="28">
                <StackPanel>
                    <TextBlock FontSize="{StaticResource FontSizeSectionTitle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="Moje sázky" />
                    <ListView Margin="0,16,0,0" Background="Transparent" BorderThickness="0" ItemsSource="{Binding RecentBets}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,10" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14" Background="#0F172ACC" BorderBrush="#2234475E" BorderThickness="1" CornerRadius="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding EventName}" />
                                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding StakeDisplay}" />
                                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding OutcomeDisplay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" Text="{Binding OddsDisplay}" />
                                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Right" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding PotentialPayoutDisplay}" />
                                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Right" Foreground="#94A3B8" Text="{Binding PlacedAtDisplay}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Column="1" Padding="22" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="{StaticResource FontSizeSectionTitle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="Sázení na události" />
                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding QuoteSummary}" TextWrapping="Wrap" />
                </StackPanel>

                <DockPanel Grid.Row="1" Margin="0,16,0,0" LastChildFill="False">
                    <ComboBox Width="360" ItemsSource="{Binding Markets}" SelectedItem="{Binding SelectedMarket}" DisplayMemberPath="EventName" />
                    <TextBox Width="140" Margin="12,0,0,0" Text="{Binding StakeAmount, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Width="160" Margin="12,0,0,0" Command="{Binding PlaceBetCommand}" Content="Vsadit D3Kredit" />
                </DockPanel>

                <ListView Grid.Row="2" Margin="0,18,0,0" Background="Transparent" BorderThickness="0" ItemsSource="{Binding Markets}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,10" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14" Background="#0F172ACC" BorderBrush="#2234475E" BorderThickness="1" CornerRadius="18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="{Binding EventName}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding StatusDisplay}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Text="{Binding OddsDisplay}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>
