<Window x:Class="BettingApp.Wpf.Views.CustomerDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="D3Bet | Zákaznická obrazovka"
        Width="1600"
        Height="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#050B16"
        KeyDown="WindowKeyDown">
    <Window.Resources>
        <LinearGradientBrush x:Key="BackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#050B16" Offset="0" />
            <GradientStop Color="#0A1730" Offset="0.5" />
            <GradientStop Color="#10254A" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PanelBrush" Color="#D60D1728" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#F97316" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />

        <Style x:Key="TileStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="#224A617C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,18,18" />
        </Style>

        <Style x:Key="InfoTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="#17263B" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="420" Height="420" Canvas.Left="-120" Canvas.Top="-100" Fill="#18F97316" />
            <Ellipse Width="320" Height="320" Canvas.Right="80" Canvas.Top="30" Fill="#1538BDF8" />
            <Ellipse Width="280" Height="280" Canvas.Left="1120" Canvas.Top="620" Fill="#1822C55E" />
        </Canvas>

        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Text="D3BET LIVE" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="48"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               Text="Kurzový grid pro zákazníky" />
                    <TextBlock Margin="0,12,0,0"
                               Style="{StaticResource InfoTextStyle}"
                               Text="Veřejná obrazovka ukazuje aktuální kurz a celkový vsazený objem na jednotlivé události." />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Margin="0,0,12,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Content="Obnovit"
                            Click="RefreshButtonClick" />
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Content="Zavřít obrazovku"
                            Click="CloseButtonClick" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,22,0,20"
                    Padding="18,14"
                    Background="#A80B1526"
                    BorderBrush="#2234475E"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="14" Height="14" Margin="0,0,12,0" Background="{StaticResource SuccessBrush}" CornerRadius="999" VerticalAlignment="Center" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Text="Živý přehled je aktivní" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="20"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Text="{Binding CustomerDisplayUpdatedAt}" />
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <ItemsControl ItemsSource="{Binding CustomerDisplayTiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource TileStyle}">
                                <StackPanel>
                                    <Border Width="54"
                                            Height="8"
                                            HorizontalAlignment="Left"
                                            CornerRadius="999"
                                            Background="{Binding AccentBrush}" />
                                    <TextBlock Margin="0,18,0,0"
                                               FontSize="30"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               Text="{Binding EventName}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,22,0,0"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="20"
                                               Text="Aktuální kurz" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="54"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="{Binding OddsDisplay}" />

                                    <Border Margin="0,22,0,0"
                                            Padding="16,14"
                                            Background="#120F172A"
                                            BorderBrush="#1F334155"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontSize="18"
                                                           Text="Celkem vsazeno" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="34"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                           Text="{Binding TotalStakeDisplay}" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Padding="12,8"
                                                    Background="#17263B"
                                                    CornerRadius="14"
                                                    VerticalAlignment="Center">
                                                <TextBlock Foreground="#93C5FD"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding TicketCountDisplay}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <Border Grid.Row="3"
                    Margin="0,24,0,0"
                    Padding="18,14"
                    Background="#A80B1526"
                    BorderBrush="#2234475E"
                    BorderThickness="1"
                    CornerRadius="18">
                <TextBlock FontSize="18"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Text="Tip: obrazovka je připravená pro velké panely i kiosky. Interní provozní údaje, provize a neveřejné detaily zůstávají skryté." />
            </Border>
        </Grid>
    </Grid>
</Window>
